# =====================================
# (1) Export ACTUAL graphene dims to file
# =====================================

shell rm -f build_dims.vars

units          real
atom_style     full
boundary       p p f

variable gfile  string /mnt/c/Users/vbarv/Desktop/vns/course/project/lammps/data/graphene_flat_initial.data
read_data      ${gfile}

group C type 1

# --- FIX ---
compute xC_min C reduce min x
compute xC_max C reduce max x
compute yC_min C reduce min y
compute yC_max C reduce max y
compute cZ_max C reduce max z

run 0 post no

variable xmin_g equal c_xC_min
variable xmax_g equal c_xC_max
variable ymin_g equal c_yC_min
variable ymax_g equal c_yC_max

# Calculate dimensions and center based on ATOM positions
variable Lx_g   equal ${xmax_g}-${xmin_g}
variable Ly_g   equal ${ymax_g}-${ymin_g}
variable xmid_g equal 0.5*(${xmax_g}+${xmin_g})
variable ymid_g equal 0.5*(${ymax_g}+${ymin_g})
variable zmaxC  equal c_cZ_max

# dump reusable vars
print "variable Lx_g  equal ${Lx_g}"    file   build_dims.vars screen no
print "variable Ly_g  equal ${Ly_g}"    append build_dims.vars screen no
print "variable xmid_g equal ${xmid_g}"  append build_dims.vars screen no
print "variable ymid_g equal ${ymid_g}"  append build_dims.vars screen no
print "variable zmaxC  equal ${zmaxC}"   append build_dims.vars screen no

uncompute xC_min
uncompute xC_max
uncompute yC_min
uncompute yC_max
uncompute cZ_max
clear


# ===================
# (2) WATER CYLINDER
# ===================

units          real
atom_style     full
boundary       p p p                 
pair_style     zero 10.0             
bond_style     zero
angle_style    zero
kspace_style   none
special_bonds  lj/coul 0.0 0.0 0.5

read_data      /mnt/c/Users/vbarv/Desktop/vns/course/project/lammps/data/water_equilibrated_for_droplet_nocoef.data

mass           1 15.9994             # O
mass           2 1.008               # H

include        build_dims.vars
group          W type 1 2            # <-- define water group

# match graphene length along Y
variable Ny equal ceil(${Ly_g}/ly)
replicate 1 ${Ny} 1
change_box all y final 0.0 ${Ly_g} remap units box

variable wx equal xcm(W,x)
variable wz equal xcm(W,z)
variable R  equal 25.0
region keep_cyl cylinder y ${wx} ${wz} ${R} EDGE EDGE units box
group  keep  region keep_cyl
group  drop  subtract W keep
delete_atoms group drop mol yes

set group all image 0 0 0
change_box all boundary f f f
pair_style  none
bond_style  none
angle_style none
kspace_style none

write_data /mnt/c/Users/vbarv/Desktop/vns/course/project/lammps/data/water_cylinder.data nocoeff
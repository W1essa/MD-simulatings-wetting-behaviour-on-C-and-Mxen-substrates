# ======================================
# Merge Water + Graphene (v6.3 - max/bonds fix)
# ======================================

# --- 1. Initialization ---
units          metal
atom_style     full
boundary       p p f  # Periodic in XY, Fixed in Z
atom_modify    map array

bond_style     harmonic
angle_style    harmonic

# --- 2. System Definition ---
# Final box size from graphene relaxation
variable Lx0 equal 243.16743481791
variable Ly0 equal 390.287345812183

# Final Z boundaries
variable z_height equal 150.0
variable z_bottom equal -40.0

# --- 3. Create Final Box ---
# Create an empty box with correct dimensions and types
region main_box block 0.0 ${Lx0} 0.0 ${Ly0} ${z_bottom} ${z_height} units box

# <<< FIX: Explicitly set max bonds/angles
# We tell LAMMPS the absolute max values needed for the *combined* system:
# max/bonds/per/atom 3  (for Graphene)
# max/angles/per/atom 1 (for Water)
create_box 4 main_box max/bonds/per/atom 3 max/angles/per/atom 1 bond/types 1 angle/types 1

# --- 4. Read Data into Box ---
# Read water (types 1,2)
read_data /mnt/c/Users/vbarv/Desktop/vns/course/project/lammps/data/water_cylinder.data add append shift 0 0 0 group W

# Read graphene (types 1,2 -> 3,4)
read_data /mnt/c/Users/vbarv/Desktop/vns/course/project/lammps/data/graphene_flat_relaxed.data add append shift 0 0 0 group G offset 2 0 0 0 0

# --- 5. Define Force Field Parameters ---
# (These will be used by the next script)
mass           1 15.9994 # O
mass           2 1.008   # H
mass           3 12.011  # C
mass           4 1.008   # H (graphene)

group          t3 type 3
group          t4 type 4
set group t3 charge 0.0 # Graphene C
set group t4 charge 0.0 # Graphene H

bond_coeff     1 0.0 1.0
angle_coeff    1 0.0 109.47

# --- 6. Alignment ---
# 'shift 0 0 0' has already centered both groups in XY.
# Now we just move water up in Z.

variable gcz equal xcm(G,z)     # Graphene Z-center
variable wcz equal xcm(Z,W)     # Water Z-center
variable gap equal 20.0         # Desired Z-gap (center-to-center)

# Calculate displacement to move water above graphene
variable dWz     equal $(v_gcz + v_gap - v_wcz)
displace_atoms W move 0.0 0.0 ${dWz} units box

# --- 7. Final Output ---
reset_atoms image all
write_data /mnt/c/Users/vbarv/Desktop/vns/course/project/lammps/data/merged_aligned.data

print "Merge complete (create_box method)."
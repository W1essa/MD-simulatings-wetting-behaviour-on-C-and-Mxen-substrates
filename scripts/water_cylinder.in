# ============================
# BUILD WATER CYL + MERGE WITH GRAPHENE (SPC/E)
# ============================

# ----------------------------
# (1) Read graphene -> export box dims to file
# ----------------------------
shell rm -f build_dims.vars

units           real
atom_style      full
boundary        p p f

variable gfile  string /home/vanes/lammps-course/data/graphene_flat_initial.data
read_data       ${gfile}

# box geometry
variable Lx_g   equal lx
variable Ly_g   equal ly
variable xmid_g equal 0.5*(xhi+xlo)
variable ymid_g equal 0.5*(yhi+ylo)

group   C type 1      # 1=C, 2=H (edge)
compute cZ C reduce max z
run 0 post no
variable zmaxC equal c_cZ

# dump reusable vars
print "variable Lx_g   equal ${Lx_g}"    file   build_dims.vars screen no
print "variable Ly_g   equal ${Ly_g}"    append build_dims.vars screen no
print "variable xmid_g equal ${xmid_g}"  append build_dims.vars screen no
print "variable ymid_g equal ${ymid_g}"  append build_dims.vars screen no
print "variable zmaxC  equal ${zmaxC}"   append build_dims.vars screen no

uncompute cZ
clear


# ----------------------------
# (2) Build water cylinder (from equilibrated cube)
# ----------------------------
units          real
atom_style     full
boundary       p p p

# enable a style so "Pair Coeffs" from the data file can be parsed
pair_style     lj/cut/coul/long 10.0 12.0
bond_style     harmonic
angle_style    harmonic
special_bonds  lj/coul 0.0 0.0 0.5
kspace_style   pppm 1.0e-4
read_data      /home/vanes/lammps-course/data/water_equilibrated_for_droplet.data

include  build_dims.vars              # Ly_g, xmid_g, ymid_g, zmaxC

# replicate to match graphene Ly
variable Ny equal ceil(${Ly_g}/ly)
replicate 1 ${Ny} 1
change_box all y final 0.0 ${Ly_g} remap units box

# cut cylinder (axis = y), keep full y
variable xmid_w equal 0.5*(xhi+xlo)
variable zmid_w equal 0.5*(zhi+zlo)
variable R_cyl  equal 25.0

region  keep_cyl cylinder y ${xmid_w} ${zmid_w} ${R_cyl} EDGE EDGE units box
group  keep    region keep_cyl
group  outside subtract all keep
delete_atoms   group outside mol yes

variable n_all  equal count(all)
variable n_keep equal count(keep)
print "Kept atoms (cyl): ${n_keep} / ${n_all}"

write_data /home/vanes/lammps-course/data/water_cylinder.data
clear